# ---- Server ----
PORT=4000
CLIENT_URL=http://localhost:5173
TIMEZONE=Asia/Bangkok

# ---- Google OAuth (from Google Cloud Console) ----
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# ---- Session ----
# Use two long random strings (e.g. `openssl rand -hex 32`)
SESSION_KEY1=replace-with-a-long-random-string
SESSION_KEY2=replace-with-another-long-random-string

# ---- Optional: restrict sign-in to your Workspace domain ----
# Leave blank to allow any Google account.
ALLOWED_HOSTED_DOMAIN=yourcompany.com

# ---- Optional: real-time push from Google (full two-way sync) ----
# URL ของ webhook ที่ Google จะยิงมาเมื่อปฏิทินห้องเปลี่ยน
# ต้องเป็น HTTPS และ verify domain แล้ว (ดู README หัวข้อ "Real-time push")
# เว้นว่างได้ — ระบบยังเป็น two-way ผ่านการรีเฟรชสด + SSE ภายในแอป
WEBHOOK_URL=
# path ไปยังไฟล์ service account (สำหรับเปิด watch ปฏิทินห้องเบื้องหลัง)
GOOGLE_SERVICE_ACCOUNT_FILE=
